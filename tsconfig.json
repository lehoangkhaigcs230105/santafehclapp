{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "strict": false,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "ignoreDeprecations": "5.0"
  },
  "include": [
    "app",
    "src",
    "**/*.ts",
    "**/*.tsx"
  ]
}
